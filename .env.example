# Copy to `.env` and adjust. All values have working defaults.

# Public IP/DNS players connect to. MUST be set for a real deployment — it is
# baked into the rpc_url players receive. e.g. on a VPS: PUBLIC_HOST=1.2.3.4
PUBLIC_HOST=localhost

# Public host ports. OPEN BOTH in your firewall / cloud security group:
#   players run:   nc <PUBLIC_HOST> <NC_PORT>
#   their SDK/RPC: http://<PUBLIC_HOST>:<PROXY_PORT>/<uuid>
NC_PORT=1337
PROXY_PORT=8080

# Which challenge under ./challenges to serve.
CHALLENGE=placeholder-flashpool

# Sui release pinned into the instance image (must have Linux release assets).
SUI_VERSION=mainnet-v1.74.1

# Lifecycle / limits
INSTANCE_TTL_SECONDS=900     # 15 minutes
MAX_INSTANCES_PER_IP=1
MAX_TOTAL_INSTANCES=20
INSTANCE_BOOT_TIMEOUT=360

# Per-instance resource caps. `sui start` OOMs at a 1g cap — 2g is the floor.
# NOTE: MAX_TOTAL_INSTANCES * INSTANCE_MEM is worst-case RAM (20 * 2g = 40g) —
# size the host accordingly or lower MAX_TOTAL_INSTANCES.
INSTANCE_MEM=2g
INSTANCE_NANO_CPUS=1000000000   # 1.0 CPU (1e9 nanocpus)

# DNS for instance containers. Deploy-time `test-publish` fetches the Move
# framework from github, so instances need working DNS. Some VM/Colima default
# resolvers are flaky; these public resolvers are used by default. Empty = docker default.
INSTANCE_DNS=8.8.8.8,1.1.1.1

# Proof-of-work difficulty (leading zero bits). 0 disables the gate.
# ~20 bits ≈ a few seconds on a laptop. Raise for a bigger event.
POW_DIFFICULTY_BITS=20

# Optionally restrict which interface the public ports bind to on the host.
# NC_BIND=0.0.0.0
# PROXY_BIND=0.0.0.0
